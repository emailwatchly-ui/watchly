{
  "expo": {
    "name": "Watchly",
    "slug": "watchly",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "watchly",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1117"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emailwatchly.watchly",
      "config": {
        "googleMapsApiKey": "$(GOOGLE_MAPS_API_KEY)",
        "googleSignIn": {
          "reservedClientId": "128071343253-cmbv7a3i62tv55voo1qn5vga8k6icl3l.apps.googleusercontent.com"
        }
      },
      "infoPlist": {
        "NSUserNotificationUsageDescription": "Watchly sends alerts about crime activity in your area.",
        "NSLocationWhenInUseUsageDescription": "Watchly uses your location to place crime reports on the map and to auto-fill the location field when submitting a new report. For example, if you witness a theft nearby, your current location will be used to pin the report accurately."
      },
      "buildNumber": "3",
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ]
      },
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1d27"
      },
      "package": "com.watchly.app",
      "config": {
        "googleMaps": {
          "apiKey": "$(GOOGLE_MAPS_API_KEY)"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Watchly needs your location to show crime reports near you."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.128071343253-cmbv7a3i62tv55voo1qn5vga8k6icl3l"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#E53E3E",
          "sounds": []
        }
      ],
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      },
      "googleIosClientId": "128071343253-cmbv7a3i62tv55voo1qn5vga8k6icl3l.apps.googleusercontent.com",
      "googleWebClientId": "128071343253-8ibt959omp4n15sugom9ru67j1ur0rql.apps.googleusercontent.com"
    },
    "description": "Community crime awareness app for Canberra. Report and track local crime incidents on an interactive map.",
    "privacyPolicyUrl": "https://emailwatchly-ui.github.io/watchly/",
    "termsOfServiceUrl": "https://emailwatchly-ui.github.io/watchly/terms.html"
  }
}