{
  "expo": {
    "name": "Watchly",
    "slug": "watchly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "watchly",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1117"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.watchly.app",
      "config": {
        "googleMapsApiKey": "AIzaSyDGZOfREGffl34XKQE8UASxrRPLH4CRqqo"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1117"
      },
      "package": "com.watchly.app",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDGZOfREGffl34XKQE8UASxrRPLH4CRqqo"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Watchly needs your location to show crime reports near you."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}